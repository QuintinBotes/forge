# regions.env — non-secret region knobs for deploy.sh, mirroring
# variables.tf's `environments[*].{primary_region,extra_regions}` defaults.
#
# fly.toml has no top-level "regions" list for Machines-based apps: Fly
# tracks an app's region set out-of-band via `flyctl regions add/set/remove`,
# not manifest content. So extra_regions can't be "baked in" by the
# fly.toml.tftpl template (see its comment) — deploy.sh's "regions" step
# (also run automatically as part of "deploy") uses the values below to run
# `flyctl regions set <primary> <extras...>` and actually realize the
# environments[*].extra_regions input as running Fly regions.
#
# EXTRA_REGIONS entries are space-separated; empty string means "no extra
# regions for this env" (single-region app).
#
# Keep in sync with variables.tf's `environments` map — same manual sync
# contract as scaling.env (see that file + module README's CI follow-up).

DEV_PRIMARY_REGION=iad
DEV_EXTRA_REGIONS=""

STAGING_PRIMARY_REGION=iad
STAGING_EXTRA_REGIONS=""

PROD_PRIMARY_REGION=iad
PROD_EXTRA_REGIONS="ord"

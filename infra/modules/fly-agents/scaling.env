# scaling.env — non-secret machine-count knobs for deploy.sh, mirroring
# variables.tf's `environments[*].{min,max}_machines_running` defaults.
#
# This file is deliberately plain-shell (not Tofu) so deploy.sh can source
# it with zero dependency on `tofu`/`flyctl` state or network access.
# There is no per-region breakdown here: flyctl's `--min-per-region` flag
# applies MIN_MACHINES to every region the app runs in (primary + extra).
#
# Keep in sync with variables.tf's `environments` map — CI should fail the
# `tofu plan` gate if these ever drift (follow-up, see module README).
#
# FLY_ORG mirrors variables.tf's module-wide `fly_org` variable default
# (there is one org per module invocation, not one per environment). It is
# only ever used for `flyctl apps create` (org only matters at app-creation
# time — see main.tf's app_create_commands local). Override per-invocation
# with deploy.sh's `--org` flag without editing this file.

FLY_ORG=personal

DEV_MIN_MACHINES=0
DEV_MAX_MACHINES=3

STAGING_MIN_MACHINES=0
STAGING_MAX_MACHINES=5

PROD_MIN_MACHINES=1
PROD_MAX_MACHINES=10

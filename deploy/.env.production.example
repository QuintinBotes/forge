# ---------------------------------------------------------------------------
# Forge PRODUCTION environment (example) — HARD-13.
# Copy to deploy/.env, fill in real values, keep it OUT of version control.
# The api/worker/mcp-gateway fail closed (refuse to boot) without a master key.
# ---------------------------------------------------------------------------

# Canonical environment name (drives fail-closed key requirement + docs-off).
FORGE_ENVIRONMENT=production

# Instance master KEK (>= 16 bytes). REQUIRED. Generate a fresh one:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Option A — inline (compose ${FORGE_SECRET_KEY:?} fails the `up` if unset):
FORGE_SECRET_KEY=REPLACE-WITH-A-LONG-RANDOM-SECRET
# Option B — mount a Docker/K8s secret file and leave FORGE_SECRET_KEY unset;
# the app reads FORGE_SECRET_KEY from this file (the `_FILE` convention):
# FORGE_SECRET_KEY_FILE=/run/secrets/forge_secret_key

# --- KEK rotation (see docs/self-hosting/security.md) ----------------------
# During a rotation window set the NEW key as FORGE_SECRET_KEY, the PREVIOUS one
# as FORGE_SECRET_KEY_V1, bump the version, then run `secrets rotate-kek`.
# FORGE_SECRET_KEY_VERSION=2
# FORGE_SECRET_KEY_V1=PREVIOUS-KEK-REMOVE-AFTER-ROTATION

# --- Secret provider -------------------------------------------------------
# env (default) | file (reads FORGE_SECRET_FILE_ROOT/<KEY>) | vault (KV-v2).
FORGE_SECRET_PROVIDER=env
# FORGE_SECRET_FILE_ROOT=/run/secrets
# FORGE_VAULT_ADDR=https://vault.internal:8200
# FORGE_VAULT_TOKEN=REPLACE
# FORGE_VAULT_MOUNT=secret
# FORGE_VAULT_PATH=forge

# --- Crypto / tokens -------------------------------------------------------
# Two-tier envelope encryption MUST stay on in production.
FORGE_ENVELOPE_ENCRYPTION=true
# Automatic expiry (seconds) for minted agent-runner tokens.
FORGE_AGENT_TOKEN_TTL=86400
# NEVER set FORGE_DEV_INSECURE in production (it enables an ephemeral key).

# --- Datastores ------------------------------------------------------------
POSTGRES_USER=forge
POSTGRES_PASSWORD=REPLACE-WITH-A-STRONG-DB-PASSWORD
POSTGRES_DB=forge

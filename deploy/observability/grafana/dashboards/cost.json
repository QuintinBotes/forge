{
  "uid": "forge-cost",
  "title": "Forge \u2014 Cost",
  "tags": [
    "forge",
    "cost"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Model spend $/s by provider",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "forge-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "forge-prometheus"
          },
          "expr": "sum by (provider) (forge:model_cost_usd:rate5m)",
          "legendFormat": "{{provider}}",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "title": "Model spend $/s by phase",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "forge-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "forge-prometheus"
          },
          "expr": "sum by (phase) (forge:model_cost_usd:rate5m)",
          "legendFormat": "{{phase}}",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Token throughput by kind",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "forge-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "forge-prometheus"
          },
          "expr": "sum by (token_kind) (forge:model_tokens:rate5m)",
          "legendFormat": "{{token_kind}}",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Cost emit failures",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "forge-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "forge-prometheus"
          },
          "expr": "forge:cost_emit_failures:rate5m",
          "legendFormat": "{{service}} / {{reason}}",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "Unpriced model calls",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "forge-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "forge-prometheus"
          },
          "expr": "forge:unpriced_model:rate1h",
          "legendFormat": "{{provider}} / {{model}}",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "Cost pipeline logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "forge-loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "forge-loki"
          },
          "expr": "{service=\"forge-worker\"} |= \"cost\"",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}

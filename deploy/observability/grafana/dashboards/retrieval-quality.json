    {
      "id": 4,
      "title": "Hybrid hit ratio",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "forge-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "forge-prometheus"
          },
          "expr": "forge:retrieval_hit_ratio:rate5m",
          "legendFormat": "hit ratio",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "Reranker delta p50",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "forge-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "forge-prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(forge_reranker_delta_bucket[30m])))",
          "legendFormat": "p50",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {}
    },

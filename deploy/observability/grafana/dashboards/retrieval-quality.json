{
  "uid": "forge-retrieval-quality",
  "title": "Forge \u2014 Retrieval Quality",
  "tags": [
    "forge",
    "retrieval"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Retrieval latency p50 by stage (s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "forge-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "forge-prometheus"
          },
          "expr": "forge:retrieval_latency_seconds:p50",
          "legendFormat": "{{stage}}",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "title": "Retrieval latency p95 by stage (s)",

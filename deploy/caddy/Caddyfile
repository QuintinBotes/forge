# Forge — Caddy reverse proxy (plan Task 0.6).
#
# Routes the public site through a single TLS-terminating edge. Caddy obtains and
# renews certificates automatically for a real DOMAIN; for local use the default
# `localhost` serves over Caddy's internal CA.
#
#   - /api/*  -> FastAPI backend (api:8000)
#   - /mcp/*  -> MCP gateway service (mcp-gateway:8001)
#   - /*      -> Next.js frontend (web:3000)

{
	# Operational email for ACME (Let's Encrypt). Override via ACME_EMAIL.
	email {$ACME_EMAIL:admin@localhost}
}

{$DOMAIN:localhost} {
	encode gzip zstd

	# Incident alert webhooks (F17): provider signatures are HMAC over the EXACT
	# raw request bytes, so this path MUST be proxied verbatim — do NOT add any
	# request_body buffering/rewrite/transform here (same constraint as the
	# GitHub webhook). Caddy's reverse_proxy streams the body unchanged by
	# default; keep it that way.
	handle /api/v1/integrations/alerts/*/webhook {
		reverse_proxy api:8000
	}

	# External PM webhooks (F18 — Jira, Linear): Linear's HMAC-SHA256 is computed
	# over the EXACT raw request body, so this path MUST be proxied verbatim — do
	# NOT add any request_body buffering/rewrite/transform here. Caddy streams the
	# body unchanged by default; keep it that way.
	handle /api/v1/integrations/pm/webhooks/* {
		reverse_proxy api:8000
	}

	# API surface.
	handle_path /api/* {
		reverse_proxy api:8000
	}

	# Public benchmark leaderboard (F35) — unauthenticated, read-only, and a
	# no-op unless FORGE_PUBLIC_LEADERBOARD_ENABLED=true (the API returns 404
	# for every /public/* path when disabled, the self-hosted privacy default).
	# The API layer rate-limits per IP and sets Cache-Control; pass both through.
	handle /public/* {
		reverse_proxy api:8000
	}

	# Realtime WebSockets (forge_api.routers.realtime): board push (`/ws`) and
	# CRDT spec co-editing (`/ws/spec/{spec_id}`). These mount at the API app
	# ROOT — `app.include_router(realtime_router)` with no prefix (see
	# apps/api/forge_api/main.py) — so their path is a bare `/ws`, NOT `/api/ws`.
	# The web client builds the URL from NEXT_PUBLIC_WS_URL (default
	# `ws://localhost:8000/ws`, apps/web/src/lib/realtime/use-board-realtime.ts),
	# a same-origin `/ws` path with no `/api` prefix and no window.location
	# rewrite — so behind this edge an operator sets NEXT_PUBLIC_WS_URL to
	# `wss://<DOMAIN>/ws`. Without these two blocks, `/ws` and `/ws/spec/*` fall
	# through to the `web:3000` catch-all below and the socket hits Next.js
	# instead of the API — realtime silently dead behind Caddy. `handle` (not
	# `handle_path`) preserves the `/ws` prefix, which is where the API serves
	# them. Caddy's reverse_proxy auto-detects the `Upgrade` header, so
	# websockets need no extra directives here; the nginx equivalent
	# (deploy/nginx/forge.conf `location = /ws` + `location /ws/spec/`) has to
	# spell the upgrade + long-idle timeouts out by hand. These two are the
	# canonical realtime routes for BOTH proxies (edge routing parity).
	handle /ws {
		reverse_proxy api:8000
	}
	handle /ws/spec/* {
		reverse_proxy api:8000
	}

	# MCP gateway surface.
	handle_path /mcp/* {
		reverse_proxy mcp-gateway:8001
	}

	# Temporal Web UI (F25) — admin-gated, opt-in `temporal` profile. The frontend
	# (7233) is NEVER exposed; only this read-only UI, behind HTTP basic-auth.
	# Set TEMPORAL_UI_BASIC_AUTH to a `caddy hash-password` bcrypt hash to enable;
	# unset leaves the route present but locked (no credentials accepted).
	handle /_temporal* {
		basic_auth {
			admin {$TEMPORAL_UI_BASIC_AUTH:$2a$14$disabledbydefaultdisabledbydefaultdisabledbydefaultdisabledby}
		}
		reverse_proxy temporal-ui:8080
	}

	# Grafana ops dashboards (HARD-10) — opt-in `observability` profile. Grafana
	# is NEVER published on a host port; it is reached ONLY through this route,
	# behind HTTP basic-auth (in addition to Grafana's own admin login). Set
	# GRAFANA_BASIC_AUTH to a `caddy hash-password` bcrypt hash to enable; unset
	# leaves the route present but locked (no credentials accepted). Grafana is
	# configured with GF_SERVER_SERVE_FROM_SUB_PATH so /grafana is preserved
	# (use `handle`, not `handle_path`, so the /grafana prefix reaches Grafana).
	handle /grafana/* {
		basic_auth {
			admin {$GRAFANA_BASIC_AUTH:$2a$14$disabledbydefaultdisabledbydefaultdisabledbydefaultdisabledby}
		}
		reverse_proxy grafana:3000
	}

	# Everything else is the web frontend.
	handle {
		reverse_proxy web:3000
	}

	# Security headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}

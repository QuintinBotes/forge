# Forge — Caddy reverse proxy for the LOCAL DEV stack.
#
# Plain HTTP on :80 inside the container (published to the host as
# ${CADDY_PORT:-8080}). No TLS / ACME for local use. Routes:
#   - /api/*  -> FastAPI backend       (api:8000)
#   - /mcp/*  -> MCP gateway service    (mcp-gateway:8001)
#   - /*      -> Next.js dev frontend   (web:3000)

{
	admin off
	auto_https off
}

:80 {
	encode gzip

	handle_path /api/* {
		reverse_proxy api:8000
	}

	handle_path /mcp/* {
		reverse_proxy mcp-gateway:8001
	}

	handle {
		reverse_proxy web:3000
	}

	log {
		output stdout
		format console
	}
}

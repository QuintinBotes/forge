# Forge — LOCAL DEV defaults for deploy/docker-compose.dev.yml.
#
# These are SAFE, DEV-ONLY values. They are NOT secrets and MUST NOT be used in
# production. scripts/dev.sh passes this file via `--env-file`; the compose file
# also hard-codes the same defaults inline, so the one-command bring-up works
# even without this file:
#
#   docker compose -f deploy/docker-compose.dev.yml up -d --build --wait
#
# Override any value here or in your shell environment.

# --- Database (internal only; never published to the host) -------------------
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge

# --- Object storage (internal only) ------------------------------------------
MINIO_ROOT_USER=forge
MINIO_ROOT_PASSWORD=forge-dev-password

# --- App secret (dev-only; NON-secret placeholder — matches the compose default).
# For anything real, generate one: `openssl rand -base64 48` and set it in your shell.
FORGE_SECRET_KEY=dev-only-insecure-secret-change-me-0123456789abcdef

# --- Published host ports (override if any of these are taken) ----------------
WEB_PORT=3000
API_PORT=8000
CADDY_PORT=8080

# --- Frontend -> API base URL (browser-facing) -------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

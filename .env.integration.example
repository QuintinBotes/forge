# ---------------------------------------------------------------------------
# Forge INTEGRATION credentials (example — names only, HARD-13 / SPEC).
# Copy to .env.integration and fill in to run the `@pytest.mark.integration`
# live-provider tests. Absent -> those tests SKIP cleanly. Never commit values.
# ---------------------------------------------------------------------------

# --- HashiCorp Vault (VaultSecretProvider integration test) ----------------
FORGE_VAULT_ADDR=
FORGE_VAULT_TOKEN=
FORGE_VAULT_MOUNT=secret
FORGE_VAULT_PATH=forge

# --- Live third-party providers (require real credentials) -----------------
# GitHub (repo/PR/webhook), Slack, model providers — BYOK, per workspace.
FORGE_GITHUB_TOKEN=
FORGE_GITHUB_WEBHOOK_SECRET=
FORGE_SLACK_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- HARD-02: live BYOK model provider (pytest -m live_model) --------------
# FORGE_MODEL_PROVIDER selects the adapter (anthropic|openai) and is the master
# switch — unset, the worker keeps the offline scripted model. Install the extra
# with `uv sync --extra providers`. See docs/runbooks/live-model.md.
FORGE_MODEL_PROVIDER=
FORGE_MODEL_NAME=                 # required for openai; anthropic defaults to claude-opus-4-8
FORGE_MODEL_EFFORT=high           # low|medium|high|xhigh|max (anthropic)
FORGE_MODEL_MAX_TOKENS=1024       # keep the live smoke run cheap
FORGE_MODEL_TIMEOUT_S=600
FORGE_MODEL_MAX_RETRIES=2
FORGE_MODEL_BASE_URL=             # optional gateway/proxy base URL
FORGE_MODEL_PROMPT_CACHE=true     # anthropic system-prompt caching

# --- HARD-03: live BYOK cross-encoder reranker (pytest -m live_rerank) ------
# FORGE_RERANK_PROVIDER selects the reranker (fixture|jina|cohere|selfhosted) and
# is the master switch — `fixture` (default) keeps the offline deterministic
# reranker. The BYOK keys / self-hosted URL are read on demand (never a logged
# Settings field). See docs/runbooks/live-reranker.md.
FORGE_RERANK_PROVIDER=             # jina | cohere | selfhosted (unset -> fixture)
FORGE_RERANK_ENABLED=true          # false -> weighted-RRF only, no client built
FORGE_RERANK_MODEL=                # provider default if empty
FORGE_RERANK_BASE_URL=             # override (SSRF-validated); provider default if empty
FORGE_RERANK_TIMEOUT_MS=800        # per-call latency budget; exceed -> fallback
FORGE_RERANK_CANDIDATES=50         # max docs sent to the reranker (DoS bound)
FORGE_RERANK_ALLOW_INSECURE_URL=false  # required for a public selfhosted host
JINA_API_KEY=                      # BYOK key for FORGE_RERANK_PROVIDER=jina
COHERE_API_KEY=                    # BYOK key for FORGE_RERANK_PROVIDER=cohere
JINA_RERANKER_URL=                 # e.g. http://reranker:8080 for selfhosted

# --- HARD-01: live GitHub App auth (pytest -m live_github) -----------------
# The App mints its own short-lived installation tokens — no PAT is pasted. The
# private key is a PATH to a gitignored .pem (its value is never an env var).
# See docs/runbooks/live-github.md.
FORGE_GITHUB_APP_ID=
FORGE_GITHUB_INSTALLATION_ID=
FORGE_GITHUB_APP_PRIVATE_KEY_PATH=deploy/secrets/github-app.pem
FORGE_GITHUB_TEST_REPO=
# FORGE_GITHUB_API_URL=https://api.github.com   # override for GitHub Enterprise

# --- HARD-05: live MCP transport (pytest -m live_mcp) ----------------------
# MCP_LIVE_TRANSPORT is the master switch — unset/false keeps NullTransport (503
# on any live op) and the live lane SKIPS clean. The live substrate is the
# self-hosted reference server (deploy/mcp-reference/), so NO external SaaS or
# credential is required: the tests self-host a loopback server when
# MCP_SERVER_URL is unset. See docs/runbooks/live-mcp.md.
MCP_LIVE_TRANSPORT=            # true -> enable the live MCP lane
MCP_SERVER_URL=               # e.g. http://localhost:8901/mcp (unset -> self-host)
MCP_TOKEN=                    # bearer token if the server is authed (dev/integration only)
MCP_RESOURCE=                 # RFC 8707 resource indicator override (falls back to endpoint)
MCP_TRANSPORT=http            # http | stdio (integration target)
MCP_STDIO_COMMAND=            # argv for the stdio server (unset -> in-repo reference --stdio)
MCP_HTTP_TIMEOUT_S=30         # per-request timeout
MCP_PROTOCOL_VERSION=2025-06-18   # MCP revision sent in MCP-Protocol-Version
FORGE_MCP_AUDIT_BACKEND=memory    # memory | db (db persists via the platform AuditStore)

# --- Rotation drill (needs a live pgvector Postgres from HARD-01) ----------
# FORGE_TEST_DATABASE_URL=postgresql+psycopg://forge:forge@localhost:5433/forge

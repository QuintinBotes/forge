# ---------------------------------------------------------------------------
# Forge INTEGRATION credentials (example — names only, HARD-13 / SPEC).
# Copy to .env.integration and fill in to run the `@pytest.mark.integration`
# live-provider tests. Absent -> those tests SKIP cleanly. Never commit values.
# ---------------------------------------------------------------------------

# --- HashiCorp Vault (VaultSecretProvider integration test) ----------------
FORGE_VAULT_ADDR=
FORGE_VAULT_TOKEN=
FORGE_VAULT_MOUNT=secret
FORGE_VAULT_PATH=forge

# --- Live third-party providers (require real credentials) -----------------
# GitHub (repo/PR/webhook), Slack, model providers — BYOK, per workspace.
FORGE_GITHUB_TOKEN=
FORGE_GITHUB_WEBHOOK_SECRET=
FORGE_SLACK_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Rotation drill (needs a live pgvector Postgres from HARD-01) ----------
# FORGE_TEST_DATABASE_URL=postgresql+psycopg://forge:forge@localhost:5433/forge

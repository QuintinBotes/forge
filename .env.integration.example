# ---------------------------------------------------------------------------
# Forge INTEGRATION credentials (example — names only, HARD-13 / SPEC).
# Copy to .env.integration and fill in to run the `@pytest.mark.integration`
# live-provider tests. Absent -> those tests SKIP cleanly. Never commit values.
# ---------------------------------------------------------------------------

# --- HashiCorp Vault (VaultSecretProvider integration test) ----------------
FORGE_VAULT_ADDR=
FORGE_VAULT_TOKEN=
FORGE_VAULT_MOUNT=secret
FORGE_VAULT_PATH=forge

# --- Live third-party providers (require real credentials) -----------------
# GitHub (repo/PR/webhook), Slack, model providers — BYOK, per workspace.
FORGE_GITHUB_TOKEN=
FORGE_GITHUB_WEBHOOK_SECRET=
FORGE_SLACK_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- HARD-02: live BYOK model provider (pytest -m live_model) --------------
# FORGE_MODEL_PROVIDER selects the adapter (anthropic|openai) and is the master
# switch — unset, the worker keeps the offline scripted model. Install the extra
# with `uv sync --extra providers`. See docs/runbooks/live-model.md.
FORGE_MODEL_PROVIDER=
FORGE_MODEL_NAME=                 # required for openai; anthropic defaults to claude-opus-4-8
FORGE_MODEL_EFFORT=high           # low|medium|high|xhigh|max (anthropic)
FORGE_MODEL_MAX_TOKENS=1024       # keep the live smoke run cheap
FORGE_MODEL_TIMEOUT_S=600
FORGE_MODEL_MAX_RETRIES=2
FORGE_MODEL_BASE_URL=             # optional gateway/proxy base URL
FORGE_MODEL_PROMPT_CACHE=true     # anthropic system-prompt caching

# --- HARD-01: live GitHub App auth (pytest -m live_github) -----------------
# The App mints its own short-lived installation tokens — no PAT is pasted. The
# private key is a PATH to a gitignored .pem (its value is never an env var).
# See docs/runbooks/live-github.md.
FORGE_GITHUB_APP_ID=
FORGE_GITHUB_INSTALLATION_ID=
FORGE_GITHUB_APP_PRIVATE_KEY_PATH=deploy/secrets/github-app.pem
FORGE_GITHUB_TEST_REPO=
# FORGE_GITHUB_API_URL=https://api.github.com   # override for GitHub Enterprise

# --- Rotation drill (needs a live pgvector Postgres from HARD-01) ----------
# FORGE_TEST_DATABASE_URL=postgresql+psycopg://forge:forge@localhost:5433/forge
